# Copy to functions/.env for emulator use, or set as Firebase Functions secrets/env.
# NEVER put these in config.js or commit them — GitHub Pages is public.

# Gemini (receipt OCR)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# OpenRouter → Nous Hermes
OPENROUTER_API_KEY=
HERMES_MODEL=nousresearch/hermes-4-70b

# Twilio SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
# Full public URL of the smsInbound function (for signature validation)
TWILIO_WEBHOOK_URL=https://us-central1-YOUR_PROJECT.cloudfunctions.net/smsInbound
# Set to 1 only for local testing without signature checks
TWILIO_SKIP_SIGNATURE=0

REMINDER_TZ=America/New_York
