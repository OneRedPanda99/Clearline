rules_version = '2';
// Clearline static HTML app — publish in Firebase Console → Firestore → Rules
service cloud.firestore {
  match /databases/{db}/documents {

    function signedIn() { return request.auth != null; }
    function uid() { return request.auth.uid; }

    function userRef() { return /databases/$(db)/documents/users/$(uid()); }
    function hasUserDoc() { return signedIn() && exists(userRef()); }
    function userDoc() { return get(userRef()); }

    function role() {
      return hasUserDoc() && userDoc().data.role is string ? userDoc().data.role : "worker";
    }

    function perms() {
      return hasUserDoc() && userDoc().data.permissions is map ? userDoc().data.permissions : {};
    }

    function perm(flag) {
      return role() == "owner" || (perms()[flag] == true);
    }

    function isOwner() { return signedIn() && role() == "owner"; }
    function isManager() { return signedIn() && role() == "manager"; }
    function isWorker() { return signedIn() && role() == "worker"; }

    // Owner provisions workers/managers from manager-panel (Auth uid != doc id on create)
    function ownerProvisioningUser() {
      return isOwner()
        && request.resource.data.createdBy == uid()
        && request.resource.data.role is string
        && request.resource.data.role in ["manager", "worker"];
    }

    // Privileged fields on a user doc that must never be changed by the
    // account holder themselves (only the Owner may grant/revoke roles and
    // permissions). Comparing request vs resource covers merge-writes: the
    // post-write state must equal the stored value for each locked field.
    function roleUnchanged()   { return request.resource.data.role == resource.data.role; }
    function permsUnchanged()  { return request.resource.data.permissions == resource.data.permissions; }
    function mgrUnchanged()    { return request.resource.data.assignedManager == resource.data.assignedManager; }
    function activeUnchanged() { return request.resource.data.active == resource.data.active; }

    // ── users/{uid} ─────────────────────────────
    match /users/{userId} {
      allow read: if signedIn() && (uid() == userId || isOwner() || isManager());
      allow create: if signedIn() && (uid() == userId || ownerProvisioningUser());

      // Update matrix:
      //   Owner   -> may change anything on any user doc.
      //   Self    -> may update own doc (settings, sync state, displayName)
      //              but NOT role/permissions/assignedManager/active.
      //   Manager -> may update only their OWN workers, and may toggle
      //              `active` (deactivate) but never role/permissions/
      //              assignedManager. Cannot touch the Owner or peers.
      allow update: if isOwner()
        || (uid() == userId
            && roleUnchanged() && permsUnchanged() && mgrUnchanged() && activeUnchanged())
        || (isManager()
            && resource.data.assignedManager == uid()
            && roleUnchanged() && permsUnchanged() && mgrUnchanged());

      allow delete: if isOwner();
    }

    // ── settings/global ─────────────────────────
    match /settings/global {
      allow read: if signedIn();
      allow write: if isOwner();
    }

    // ── customers/{id} ──────────────────────────
    match /customers/{id} {
      allow read: if signedIn();

      allow create: if signedIn()
        && perm("canCreateCustomers")
        && request.resource.data.createdBy == uid();

      allow update: if isOwner()
        || (perm("canEditOwnCustomers")
            && resource.data.createdBy == uid()
            && request.resource.data.createdBy == resource.data.createdBy);

      allow delete: if isOwner();
    }

    // ── jobs/{id} ───────────────────────────────
    // A job can have a crew of several workers now (assignedWorkers, a
    // list), not just one. `assignedTo` (a single uid) is kept as a
    // read-only fallback for older job docs written before this change.
    //
    // CRITICAL RULES/QUERY CONTRACT:
    // Firestore security rules are NOT filters. A query is rejected
    // outright (permission-denied) if it *could* return a document the
    // rule doesn't grant — and the rule is evaluated against the query's
    // POTENTIAL result set, not the actual documents. Any `get()`/`exists()`
    // call (like reading the caller's own user doc for their role) cannot
    // be proven per-document, so the whole query fails for non-owner roles.
    // Therefore the read rule below must match the `where()` clause the
    // client actually uses, with NO get()/exists() call.
    //
    // SOLUTION: each job carries an `accessUids` array (denormalized at
    // write time) listing every uid allowed to read it — the owner, the
    // assigned manager, every crew worker, and the creator. The list rule
    // `uid() in resource.data.accessUids` is fully provable from the query's
    // own `where('accessUids','array-contains',uid)` clause. No get() needed.
    // The client builds this array in _stampForCloud() before writing.
    function isAssignedWorker() {
      return (resource.data.assignedWorkers is list && uid() in resource.data.assignedWorkers)
        || resource.data.assignedTo == uid();
    }

    // True if the incoming write preserves every uid already in accessUids
    // (no reader can be silently removed by a non-owner writer) while still
    // allowing the owner to add/remove readers.
    function accessUidsPreservedOrOwner() {
      return isOwner()
        || (request.resource.data.accessUids is list
            && resource.data.accessUids is list
            && request.resource.data.accessUids.hasAll(resource.data.accessUids));
    }

    match /jobs/{id} {
      // get: a single doc. Allow if accessUids grants the caller, OR a
      // legacy field directly names them (back-compat for jobs written
      // before accessUids existed).
      allow get: if signedIn()
        && (resource.data.accessUids is list && uid() in resource.data.accessUids
            || resource.data.assignedWorkers is list && uid() in resource.data.assignedWorkers
            || resource.data.assignedTo == uid()
            || resource.data.createdBy == uid()
            || resource.data.assignedManager == uid());

      // list: must be provable from the query's own where() clause. The
      // client queries where('accessUids','array-contains',uid) for new
      // jobs, which is proven by the first clause. The legacy clauses
      // below are guarded by the SAME corresponding where() the client
      // would need (they only help if a query actually scopes by that
      // field) — but since the client now always queries accessUids, the
      // legacy fallback mainly keeps get() working and avoids a forced
      // backfill of old data.
      allow list: if signedIn()
        && (resource.data.accessUids is list && uid() in resource.data.accessUids
            || resource.data.assignedWorkers is list && uid() in resource.data.assignedWorkers
            || resource.data.assignedTo == uid()
            || resource.data.createdBy == uid()
            || resource.data.assignedManager == uid());

      // On create the writer must stamp accessUids including at least
      // themselves, the owner, the assigned manager, and all crew workers.
      allow create: if signedIn()
        && (isOwner() || isManager() || perm("canCreateJobs"))
        && request.resource.data.createdBy == uid()
        && request.resource.data.accessUids is list
        && uid() in request.resource.data.accessUids;

      allow update: if isOwner()
        || (isManager()
            && perm("canEditOwnJobs")
            && resource.data.assignedManager == uid()
            && request.resource.data.createdBy == resource.data.createdBy)
        || (isWorker()
            && perm("canEditOwnJobs")
            && (resource.data.createdBy == uid() || isAssignedWorker())
            && request.resource.data.createdBy == resource.data.createdBy);
        // Any non-owner update must preserve the existing reader set.
        && accessUidsPreservedOrOwner();

      allow delete: if isOwner();
    }

    // ── estimates/{id} ──────────────────────────
    // Read is split into get/list for the same reason as jobs: the
    // isManager()/estLinkedToMyTeam()/estCreatorIsMyWorker() branches call
    // get()/exists(), which makes a LIST query unprovable and rejected.
    // The client only ever queries estimates by where('userId','==',uid)
    // (see customer-tracker.html), which is provable below. Single-doc
    // gets may additionally use the manager/owner branches (get() is fine
    // for get, only forbidden for list).
    match /estimates/{id} {

      function jobSnap(jobId) {
        return get(/databases/$(db)/documents/jobs/$(jobId));
      }

      function estLinkedToMyTeam() {
        return (resource.data.jobId is string)
          && exists(/databases/$(db)/documents/jobs/$(resource.data.jobId))
          && jobSnap(resource.data.jobId).data.assignedManager == uid();
      }

      function estCreatorIsMyWorker() {
        return !(resource.data.jobId is string)
          && (resource.data.createdBy is string)
          && exists(/databases/$(db)/documents/users/$(resource.data.createdBy))
          && get(/databases/$(db)/documents/users/$(resource.data.createdBy)).data.assignedManager == uid();
      }

      // LIST: provable from the query's own where() fields only (no get()).
      allow list: if signedIn()
        && (resource.data.userId == uid() || resource.data.createdBy == uid());

      // GET: single-doc fetch may use the get()-based manager/owner branches.
      allow get: if signedIn()
        && (resource.data.userId == uid()
            || resource.data.createdBy == uid()
            || isOwner()
            || (isManager() && (estLinkedToMyTeam() || estCreatorIsMyWorker())));

      allow create: if signedIn()
        && perm("canUseEstimateForm")
        && request.resource.data.createdBy == uid();

      allow update: if isOwner()
        || resource.data.createdBy == uid()
        || (isManager() && perm("canUseEstimateForm") && (estLinkedToMyTeam() || estCreatorIsMyWorker()));

      allow delete: if isOwner();
    }

    // ── invoices/{id} ───────────────────────────
    // Same get/list split as estimates. Client queries invoices by
    // where('userId','==',uid) (customer-tracker.html) — provable.
    match /invoices/{id} {
      allow list: if signedIn()
        && (resource.data.userId == uid() || resource.data.createdBy == uid());

      allow get: if signedIn()
        && (resource.data.userId == uid()
            || resource.data.createdBy == uid()
            || isOwner());

      allow create: if signedIn()
        && (isOwner() || perm("canUseEstimateForm"))
        && request.resource.data.createdBy == uid();

      allow update: if isOwner()
        || resource.data.createdBy == uid()
        || resource.data.userId == uid();

      allow delete: if isOwner();
    }

    // ── expenses / payroll (Money page, owner-only) ──
    match /expenses/{id} {
      allow read, write: if isOwner();
    }
    match /payroll/{id} {
      allow read, write: if isOwner();
    }

    // ── activityLog/{id} (immutable audit trail, Owner-only viewing) ──
    match /activityLog/{id} {
      allow read: if isOwner();
      allow create: if signedIn() && request.resource.data.actorUid == uid();
      allow update, delete: if false;
    }
  }
}
