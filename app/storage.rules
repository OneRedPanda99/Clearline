rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function signedIn() { return request.auth != null; }

    function isMember(orgId) {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/orgs/$(orgId)/members/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/orgs/$(orgId)/members/$(request.auth.uid)).data.active == true;
    }

    function role(orgId) {
      return firestore.get(/databases/(default)/documents/orgs/$(orgId)/members/$(request.auth.uid)).data.role;
    }

    function isManagerPlus(orgId) {
      return isMember(orgId) && (role(orgId) == 'owner' || role(orgId) == 'manager');
    }

    // orgs/{orgId}/jobs/{jobId}/photos/{file}
    match /orgs/{orgId}/jobs/{jobId}/photos/{file} {
      allow read: if isMember(orgId);
      allow write: if isMember(orgId)
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // orgs/{orgId}/expenses/{expenseId}/receipt/{file}
    match /orgs/{orgId}/expenses/{expenseId}/receipt/{file} {
      allow read: if isManagerPlus(orgId);
      allow write: if isManagerPlus(orgId)
        && request.resource.size < 10 * 1024 * 1024;
    }
  }
}
