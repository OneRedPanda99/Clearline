rules_version = '2';

// Clearline Firestore security rules.
// All business data lives under orgs/{orgId}/* and is gated by membership.
// users/{uid} holds private per-user prefs only.
// invites/{inviteId} is readable by the invited email and writable by org owners.

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function memberDoc(orgId) {
      return get(/databases/$(database)/documents/orgs/$(orgId)/members/$(request.auth.uid));
    }

    function isMember(orgId) {
      return signedIn()
        && exists(/databases/$(database)/documents/orgs/$(orgId)/members/$(request.auth.uid))
        && memberDoc(orgId).data.active == true;
    }

    function role(orgId) {
      return memberDoc(orgId).data.role;
    }

    function isOwner(orgId)   { return isMember(orgId) && role(orgId) == 'owner'; }
    function isManagerPlus(orgId) { return isMember(orgId) && (role(orgId) == 'owner' || role(orgId) == 'manager'); }
    function isWorker(orgId)  { return isMember(orgId) && role(orgId) == 'worker'; }

    function authorEmail() {
      return request.auth.token.email;
    }

    // ─── users/{uid} (private prefs) ────────────────────────────────────
    match /users/{uid} {
      allow read: if isSelf(uid);
      allow create, update: if isSelf(uid);
      allow delete: if false;
    }

    // ─── invites (cross-org pending invitations) ────────────────────────
    match /invites/{inviteId} {
      // Anyone signed in can read invites that match their email — needed
      // so the onboarding screen can list pending invites by email.
      allow read: if signedIn() && (
        resource.data.email == authorEmail() ||
        (resource.data.orgId is string && isManagerPlus(resource.data.orgId))
      );

      // Only owners/managers of the target org can create or revoke.
      allow create: if signedIn()
        && request.resource.data.orgId is string
        && isManagerPlus(request.resource.data.orgId)
        && request.resource.data.status == 'pending';

      // The invited user (matching email) may transition to 'accepted'.
      // Owners/managers may revoke.
      allow update: if signedIn() && (
        (resource.data.email == authorEmail()
          && request.resource.data.status == 'accepted')
        || isManagerPlus(resource.data.orgId)
      );

      allow delete: if signedIn() && isManagerPlus(resource.data.orgId);
    }

    // ─── orgs/{orgId} ────────────────────────────────────────────────────
    match /orgs/{orgId} {
      // Anyone signed in can read the org doc if they are a member; otherwise
      // they cannot enumerate. Members read for org name/branding.
      allow read: if isMember(orgId)
        // Allow read during create flow when the doc is being created with
        // ownerUid == request.auth.uid (rule re-evaluates against the new doc
        // for `request.resource`, so this branch covers the bootstrap call).
        || (signedIn() && resource == null);

      // Creating an org doc is allowed when the caller is establishing
      // themselves as the owner.
      allow create: if signedIn()
        && request.resource.data.ownerUid == request.auth.uid;

      // Owner can update org metadata. Cannot change ownerUid arbitrarily.
      allow update: if isOwner(orgId)
        && request.resource.data.ownerUid == resource.data.ownerUid;

      allow delete: if false; // deletion handled out-of-band
    }

    // ─── orgs/{orgId}/members/{uid} ─────────────────────────────────────
    match /orgs/{orgId}/members/{uid} {
      // Read members if you're a member of the org; also during create flow
      // when first member doc is being placed.
      allow read: if isMember(orgId) || isSelf(uid);

      // Bootstrap: when the caller is creating their own owner doc as part
      // of org creation, allow it.
      allow create: if signedIn() && (
        // owner bootstrap (org creation)
        (isSelf(uid) && request.resource.data.role == 'owner')
        // owner/manager adding/inviting other members directly
        || isManagerPlus(orgId)
        // accepting an invite: the new member writes their own doc with
        // an `inviteId` that points to a still-pending invite for them.
        || (
          isSelf(uid)
          && request.resource.data.inviteId is string
          && exists(/databases/$(database)/documents/invites/$(request.resource.data.inviteId))
          && get(/databases/$(database)/documents/invites/$(request.resource.data.inviteId)).data.email == authorEmail()
          && get(/databases/$(database)/documents/invites/$(request.resource.data.inviteId)).data.orgId == orgId
          && get(/databases/$(database)/documents/invites/$(request.resource.data.inviteId)).data.role == request.resource.data.role
          && get(/databases/$(database)/documents/invites/$(request.resource.data.inviteId)).data.status == 'pending'
        )
      );

      // Owner can change anyone's role/active. Self can update displayName/email,
      // hourlyRateCents, and other non-permission fields.
      allow update: if isOwner(orgId)
        || (isSelf(uid)
            && request.resource.data.role == resource.data.role
            && request.resource.data.active == resource.data.active);

      allow delete: if isOwner(orgId);
    }

    // ─── orgs/{orgId}/customers/{customerId} ────────────────────────────
    match /orgs/{orgId}/customers/{customerId} {
      allow read: if isMember(orgId);
      allow create: if isManagerPlus(orgId)
        && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if isManagerPlus(orgId);
    }

    // ─── orgs/{orgId}/jobs/{jobId} ──────────────────────────────────────
    match /orgs/{orgId}/jobs/{jobId} {
      allow read: if isMember(orgId);

      // Workers can only see jobs they're assigned to or created (read filter
      // is at the query layer; rules still allow the read above for
      // simplicity since members are trusted within an org).

      allow create: if isManagerPlus(orgId)
        && request.resource.data.createdBy == request.auth.uid;

      // Workers may update only specific fields (timer, notes, photos, status to in_progress/completed).
      allow update: if isManagerPlus(orgId) || (
        isWorker(orgId)
        && (
          // worker is assigned to this job
          (resource.data.assignedTo is list && resource.data.assignedTo.hasAny([request.auth.uid]))
          || resource.data.createdBy == request.auth.uid
        )
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status','timer','laborMinutesByUid','notes','photos','updatedAt'])
      );

      allow delete: if isManagerPlus(orgId);
    }

    // ─── orgs/{orgId}/estimates ─────────────────────────────────────────
    match /orgs/{orgId}/estimates/{estimateId} {
      allow read: if isMember(orgId);
      allow create: if isManagerPlus(orgId)
        && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if isManagerPlus(orgId);
    }

    // ─── orgs/{orgId}/invoices ──────────────────────────────────────────
    match /orgs/{orgId}/invoices/{invoiceId} {
      allow read: if isMember(orgId);
      allow create: if isManagerPlus(orgId)
        && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if isManagerPlus(orgId);
    }

    // ─── orgs/{orgId}/expenses ──────────────────────────────────────────
    match /orgs/{orgId}/expenses/{expenseId} {
      // Only manager+ can read expenses (financial data).
      allow read: if isManagerPlus(orgId);
      allow create: if isManagerPlus(orgId)
        && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if isManagerPlus(orgId);
    }

    // ─── orgs/{orgId}/payruns ───────────────────────────────────────────
    match /orgs/{orgId}/payruns/{payrunId} {
      allow read: if isManagerPlus(orgId);
      allow create, update, delete: if isOwner(orgId);
    }

    // ─── orgs/{orgId}/taxCategories ─────────────────────────────────────
    match /orgs/{orgId}/taxCategories/{taxCategoryId} {
      allow read: if isMember(orgId);
      allow create, update, delete: if isOwner(orgId);
    }

    // ─── orgs/{orgId}/settings ──────────────────────────────────────────
    match /orgs/{orgId}/settings/{docId} {
      allow read: if isMember(orgId);
      allow write: if isOwner(orgId);
    }
  }
}
